package com.Easycalculation.Pages;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;

public class LoginEasyCal {
	WebDriver driver;
	public LoginEasyCal(WebDriver driver) {
		this.driver=driver;
	}
	@FindBy(id = "log_email")
	WebElement email;
	@FindBy(id = "log_password")
	WebElement password;
	
	@FindBy(xpath = "//*[@id=\"log_frm\"]/div[4]/input[2]")
	WebElement registerbtn;
	
	//create method
	public void loginEasyCal(String uname,String pass) {
		email.sendKeys(uname);
		password.sendKeys(pass);
		registerbtn.click();
	}
	
	
}
